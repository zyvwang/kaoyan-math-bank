{
  "name": "kaoyan-math-bank",
  "version": "0.1.1",
  "description": "A local-first LaTeX question bank for kaoyan math study.",
  "author": "Kaoyan Math Bank contributors",
  "private": true,
  "engines": {
    "node": ">=24 <25"
  },
  "license": "MIT",
  "main": "build/electron/main.js",
  "type": "module",
  "scripts": {
    "postinstall": "node scripts/copy-mathjax.mjs",
    "dev": "concurrently -k -n api,web -c cyan,green \"cross-env KMB_DEV_SERVER_URL=http://127.0.0.1:5173 tsx watch server/index.ts\" \"vite --host 127.0.0.1\"",
    "dev:api": "cross-env KMB_DEV_SERVER_URL=http://127.0.0.1:5173 tsx watch server/index.ts",
    "dev:web": "vite --host 127.0.0.1",
    "desktop:dev": "npm run build:desktop && concurrently -k -n web,electron -c green,blue \"vite --host 127.0.0.1\" \"wait-on http://127.0.0.1:5173 && cross-env KMB_DEV_SERVER_URL=http://127.0.0.1:5173 electron .\"",
    "typecheck": "tsc -b && tsc -p tsconfig.desktop.json --noEmit",
    "build:desktop": "tsc -p tsconfig.desktop.json",
    "build": "npm run typecheck && vite build && npm run build:desktop",
    "lint": "eslint .",
    "start": "tsx server/index.ts",
    "start:prod": "node build/server/index.js",
    "migrate:legacy": "tsx scripts/migrate-legacy-workspace.ts",
    "migrate:v2": "tsx scripts/migrate-v2-workspace.ts",
    "test:unit": "vitest run --config vitest.node.config.ts tests/unit",
    "test:api": "vitest run --config vitest.node.config.ts tests/api",
    "test:electron": "vitest run --config vitest.node.config.ts tests/electron",
    "test:ui": "vitest run --config vitest.ui.config.ts",
    "test": "npm run test:unit && npm run test:api && npm run test:electron && npm run test:ui",
    "test:coverage": "vitest run --config vitest.node.config.ts --coverage",
    "test:desktop": "playwright test --config playwright.config.ts",
    "verify": "npm run lint && npm run test && npm run build && npm run test:coverage && cross-env KMB_WORKSPACE_DIR=.tmp/verify-workspace tsx scripts/verify-export.ts",
    "dist": "npm run build && electron-builder --publish never",
    "dist:mac": "npm run build && electron-builder --mac dmg --publish never && node scripts/cleanup-macos-unpacked.mjs",
    "dist:win": "npm run build && electron-builder --win nsis --publish never"
  },
  "dependencies": {
    "@codemirror/language": "^6.12.3",
    "@codemirror/legacy-modes": "^6.5.3",
    "@codemirror/state": "^6.5.2",
    "@codemirror/view": "^6.43.1",
    "@uiw/react-codemirror": "^4.25.10",
    "express": "^5.2.1",
    "lucide-react": "^1.17.0",
    "mathjax": "^4.1.2",
    "multer": "^2.1.1",
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@playwright/test": "^1.60.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/express": "^5.0.6",
    "@types/multer": "^2.1.0",
    "@types/node": "^24.13.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@types/supertest": "^7.2.0",
    "@vitejs/plugin-react": "^5.1.1",
    "@vitest/coverage-v8": "^4.1.8",
    "concurrently": "^10.0.3",
    "cross-env": "^10.1.0",
    "electron": "^42.4.0",
    "electron-builder": "^26.15.2",
    "eslint": "^9.39.4",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.26",
    "globals": "^17.6.0",
    "jsdom": "^29.1.1",
    "supertest": "^7.2.2",
    "tsx": "^4.22.4",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.61.0",
    "vite": "^8.0.16",
    "vitest": "^4.1.8",
    "wait-on": "^9.0.10"
  },
  "build": {
    "appId": "com.kaoyanmathbank.app",
    "productName": "Kaoyan Math Bank",
    "extraMetadata": {
      "kmbUseMockKeychain": true
    },
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "build/**/*",
      "package.json"
    ],
    "mac": {
      "category": "public.app-category.education",
      "target": [
        "dmg"
      ]
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true
    }
  }
}
